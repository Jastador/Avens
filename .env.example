# Avens local configuration

# Copy this file to .env, then uncomment and adjust only the settings you need.

#

# Keep .env private. Do not commit API keys, Cloudinary credentials, local paths,

# personal profile data, or custom model names.

#

# Avens starts with its brain and camera in offline/local mode.

# Online GPT, Gemini, and Lens Scan features remain unavailable until you

# explicitly switch the relevant runtime mode through voice control.

# -----------------------------------------------------------------------------

# Local Ollama models

# -----------------------------------------------------------------------------

# Local chat model used by Avens in offline brain mode.

# The maintainer normally uses a private local Ollama model named custom_avens.

# AVENS_OLLAMA_MODEL=custom_avens

# Local vision model used for fast offline camera identification.

# AVENS_FAST_VISION_MODEL=minicpm-v4.6:1b

# Local vision model used for offline camera description and text reading.

# AVENS_DEEP_VISION_MODEL=qwen2.5vl:3b

# How long Ollama keeps the local brain model loaded after a request.

# AVENS_LOCAL_BRAIN_KEEP_ALIVE=5m

# How long Ollama keeps the fast local vision model loaded after identification.

# AVENS_FAST_VISION_KEEP_ALIVE=2m

# How long Ollama keeps the deep local vision model loaded after description/read.

# Use 0 to unload it after each request.

# AVENS_DEEP_VISION_KEEP_ALIVE=0

# -----------------------------------------------------------------------------

# Local voice, assets, and data

# -----------------------------------------------------------------------------

# Kokoro text-to-speech CPU worker count.

# AVENS_TTS_CPU_THREADS=4

# Prefer already-downloaded Hugging Face assets and avoid network downloads.

# Enable this only after required local assets are available.

# AVENS_OFFLINE_MODE=true

# Optional private local storage locations.

# AVENS_DATA_DIR=C:\Users\YourName\AppData\Local\Avens

# Semicolon-separated folders Avens may search by filename only.
# Do not use a drive root such as C:\.
# AVENS_FILE_SEARCH_ROOTS=C:\Users\YourName\Desktop;C:\Users\YourName\Documents;C:\Projects\VSCode

# AVENS_HF_HOME=C:\Path\To\HuggingFaceCache

# AVENS_PROFILE_PATH=C:\Path\To\profile.txt

# Retained for compatibility with earlier local setups.

# Runtime provider selection is controlled by Avens' spoken mode controller.

# AVENS_USE_ONLINE_AI=false

# -----------------------------------------------------------------------------

# Local performance observability

# -----------------------------------------------------------------------------

# Enable compact local JSONL timing traces. No telemetry is sent externally.

# AVENS_PERF_ENABLED=true

# Relative paths are resolved from the project root.

# AVENS_PERF_LOG_DIR=logs/performance

# Keep false unless you intentionally want raw prompts stored in local traces.

# AVENS_PERF_LOG_PROMPTS=false

# -----------------------------------------------------------------------------

# Optional online brain providers

# -----------------------------------------------------------------------------

#

# These credentials do not automatically enable online mode.

# Avens must be explicitly switched online through voice control before GPT or

# Gemini can be selected. Local profile, memory, and conversation history are

# not shared with online providers unless AVENS_SHARE_LOCAL_CONTEXT_ONLINE=true.

# Optional: OpenAI GPT brain mode.

# OPENAI_API_KEY=your_openai_api_key

# AVENS_OPENAI_MODEL=gpt-5.4-mini

# Optional: Google Gemini brain mode.

# GEMINI_API_KEY=your_gemini_api_key

# AVENS_GEMINI_MODEL=gemini-3.5-flash

# Optional and privacy-sensitive. Leave false to keep local profile, memory,

# and prior chat context out of online brain requests.

# AVENS_SHARE_LOCAL_CONTEXT_ONLINE=false

# -----------------------------------------------------------------------------

# Optional online camera Lens Scan

# -----------------------------------------------------------------------------

#

# Lens Scan requires all four values below. It is available only after the

# camera is explicitly switched online. Avens temporarily uploads one prepared

# camera image to Cloudinary for SerpApi Google Lens, then removes it afterward.

# SERPAPI_API_KEY=your_serpapi_api_key

# CLOUDINARY_CLOUD_NAME=your_cloud_name

# CLOUDINARY_API_KEY=your_cloudinary_api_key

# CLOUDINARY_API_SECRET=your_cloudinary_api_secret
